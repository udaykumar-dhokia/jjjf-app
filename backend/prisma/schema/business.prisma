enum ListingStatus {
  PENDING
  APPROVED
  REJECTED
}

enum JobType {
  VACANCY_AVAILABLE
  JOB_REQUIRED
}

enum BusinessCategory {
  AGRICULTURE
  AUTOMOTIVE
  BANKING
  CONSULTING
  EDUCATION
  ELECTRONICS
  ENTERTAINMENT
  FINANCE
  FOOD_AND_BEVERAGE
  HEALTHCARE
  HOSPITALITY
  IT
  LEGAL
  LOGISTICS
  MANUFACTURING
  MEDIA
  REAL_ESTATE
  RETAIL
  TELECOMMUNICATIONS
  TEXTILES
  TOURISM
  TRANSPORTATION
  WHOLESALE
  OTHER
}

model BusinessListing {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  ownerId String @db.ObjectId
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  businessName  String
  category      BusinessCategory
  description   String?
  logoUrl       String?
  website       String?
  contactNumber String
  address       String
  city          String
  state         String
  status        ListingStatus    @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model JobBoard {
  id         String @id @default(auto()) @map("_id") @db.ObjectId
  postedById String @db.ObjectId
  postedBy   User   @relation(fields: [postedById], references: [id], onDelete: Cascade)

  type           JobType
  roleTitle      String
  industry       String
  city           String
  salaryRange    String?
  description    String
  status         ListingStatus @default(PENDING)

  contactName    String
  contactPhone   String?
  whatsappNumber String?
  contactEmail   String?
  links          String[]      @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
