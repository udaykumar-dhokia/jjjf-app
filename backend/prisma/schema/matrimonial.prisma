enum MatrimonialStatus {
  PENDING
  APPROVED
  REJECTED
}

model MatrimonialProfile {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @unique @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  height           String?
  subCaste         String
  educationDetails String
  monthlyIncome    String?
  aboutMe          String?
  photoGallery     String[]
  biodataPdfUrl    String
  status           MatrimonialStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum AccessRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model MatrimonialAccessRequest {
  id          String              @id @default(auto()) @map("_id") @db.ObjectId
  requesterId String              @db.ObjectId
  requester   User                @relation("SentMatrimonialRequests", fields: [requesterId], references: [id], onDelete: Cascade)
  targetId    String              @db.ObjectId
  target      User                @relation("ReceivedMatrimonialRequests", fields: [targetId], references: [id], onDelete: Cascade)
  status      AccessRequestStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
