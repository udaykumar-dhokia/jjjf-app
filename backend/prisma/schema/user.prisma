enum Gender {
  MALE
  FEMALE
  OTHER
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
}

enum OccupationType {
  BUSINESS_OWNER
  JOB_PROFESSIONAL
  OTHER
}

enum Role {
  SUPER_ADMIN
  SUB_ADMIN
  STATE_ADMIN
  MEMBER
}

enum ProfileStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
  BLOCKED
}

enum RelationshipType {
  SELF
  SPOUSE
  FATHER
  MOTHER
  SON
  DAUGHTER
  GRANDSON
  GRANDDAUGHTER
  BROTHER
  SISTER
  UNCLE
  AUNT
  NEPHEW
  NIECE
  COUSIN
  FATHER_IN_LAW
  MOTHER_IN_LAW
  SON_IN_LAW
  DAUGHTER_IN_LAW
  BROTHER_IN_LAW
  SISTER_IN_LAW
  OTHER
}

model User {
  id                     String             @id @default(auto()) @map("_id") @db.ObjectId
  memberId               String?            @unique
  firstName              String
  fatherName             String
  motherName             String?
  gotra                  String
  spouseName             String?
  husbandNameWithSurname String?
  sasuralGotra           String?
  gender                 Gender
  maritalStatus          MaritalStatus
  dateOfBirth            DateTime
  bloodGroup             String?
  photoUrl               String?
  email                  String             @unique
  isEmailVerified        Boolean            @default(false)
  education              String?
  occupationType         OccupationType
  occupationDetails      OccupationDetails?
  gaon                   String
  nativeDistrict         String
  nativeState            String
  currentAddress         String?
  currentCity            String
  currentState           String
  pinCode                String?
  phoneNumber            String             @unique
  whatsappNumber         String?
  isPhoneNumberVisible   Boolean
  isProfileComplete      Boolean            @default(false)

  familyId           String?          @db.ObjectId
  family             Family?          @relation("FamilyMembers", fields: [familyId], references: [id])
  isHeadOfFamily     Boolean          @default(false)
  relationshipToHead RelationshipType?

  role           Role          @default(MEMBER)
  status         ProfileStatus @default(PENDING_APPROVAL)
  assignedStates String[]
  password       String        @default("$2b$10$M22AWip9WhljtCIkVeD7yuCXcZb0OUx/VcaIbA6w7XTDegDOHwYYG")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  phoneNumberRequests String[] @db.ObjectId

  matrimonialProfile          MatrimonialProfile?
  sentMatrimonialRequests     MatrimonialAccessRequest[] @relation("SentMatrimonialRequests")
  receivedMatrimonialRequests MatrimonialAccessRequest[] @relation("ReceivedMatrimonialRequests")
  businesses                  BusinessListing[]
  jobs                        JobBoard[]
  rsvps                       RSVP[]
  newsPosted                  News[]
  shokSandeshApproved         ShokSandesh[]              @relation("ApprovedShokSandesh")
  galleryUploaded             Gallery[]
  familiesHeaded              Family[]                   @relation("FamilyHead")
  refreshTokens               RefreshToken[]
  stateAdmins                 StateAdmin[]
}

type OccupationDetails {
  businessName String?
  category     String?
  address      String?
  contact      String?

  companyName String?
  designation String?
  industry    String?
  city        String?

  description String?
}

model Family {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  headOfFamilyId String? @db.ObjectId
  headOfFamily   User?   @relation("FamilyHead", fields: [headOfFamilyId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  familyPhotoUrl String?
  addedByUserId  String  @db.ObjectId

  members User[] @relation("FamilyMembers")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StateAdmin {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  stateName String   @unique
  adminId   String?  @db.ObjectId
  admin     User?    @relation(fields: [adminId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
